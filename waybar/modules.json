{
  // Workspaces (Japanese Kanji)
  "niri/workspaces": {
    "format": "{icon}",
    "on-click": "activate",
    "format-icons": {
      "1": "šłÄ",
      "2": "šļĆ",
      "3": "šłČ",
      "4": "Śõõ",
      "5": "šļĒ",
      "6": "ŚÖ≠",
      "7": "šłÉ",
      "8": "ŚÖę",
      "9": "šĻĚ",
      "default": "„Äá"
    }
  },

  // Media Player (Spicetify)
  "mpris": {
    "format": "<b><span color='#FF4D6D'>ūüĆĻ</span> {artist} - {title}</b>",
    "format-paused": "<b><span color='#6272A4'>ůįŹ§</span> {artist} - {title}</b>",
    "max-length": 40,
    "on-click": "~/.config/waybar/scripts/media-menu.sh",
    "ignored-players": ["zen", "zen-alpha", "firefox", "chromium", "librewolf"],
    "player-icons": {
      "default": "‚Ė∂",
      "spotify": "ÔÜľ"
    }
  },

  // Taskbar
  "wlr/taskbar": {
    "format": "{icon}",
    "icon-size": 18,
    "tooltip-format": "{title}",
    "on-click": "activate",
    "on-click-middle": "close",
    "ignore-list": ["Alacritty", "kitty", "ghostty"],
    "app_ids-mapping": {
      "firefoxdeveloperedition": "firefox-developer-edition"
    },
    "rewrite": {
      "Firefox Web Browser": "Firefox",
      "Foot Server": "Terminal",
      "Zen Browser": "Zen",
      "Brave Web Browser": "Brave"
    }
  },

  // niri Window
  "niri/window": {
    "format": "{}",
    "rewrite": {
      "(.*) - Brave": "$1",
      "(.*) - Chromium": "$1",
      "(.*) - Brave Search": "$1",
      "(.*) - Outlook": "$1",
      "(.*) Microsoft Teams": "$1"
    },
    "separate-outputs": true
  },

  // CPU Usage
  "cpu": {
    "interval": 2,
    "format": "Ôíľ    {usage}%",
    "states": {
      "high": 60
    }
  },

  // Temperature
  "temperature": {
    "interval": 2,
    "hwmon-path": "/sys/class/hwmon/hwmon1/temp1_input",
    "critical-threshold": 70,
    "format": "{icon}    {temperatureC}¬įC",
    "format-icons": ["Ôčč", "ÔčČ", "Ôčá"]
  },

  // AMD GPU Usage
  "custom/gpu": {
    "interval": 2,
    "exec": "cat /sys/class/hwmon/hwmon*/device/gpu_busy_percent",
    "format": "ůįĺ≤    {}%",
    "tooltip": false
  },

  // Empty/Tools/Updates
  "custom/empty": { "format": "" },
  "custom/tools": {
    "format": "ÔóĹ",
    "tooltip-format": "Tools"
  },
  "custom/updates": {
    "format": "{} {icon}",
    "return-type": "json",
    "format-icons": {
      "has-updates": "ůĪć∑",
      "updated": "ůįā™"
    },
    "exec-if": "which waybar-module-pacman-updates",
    "exec": "waybar-module-pacman-updates --interval-seconds 5 --network-interval-seconds 300"
  },

  // rofi Application Launcher
  "custom/appmenu": {
    "format": "    ",
    "on-click": "sleep 0.2;rofi -show drun -replace",
    "tooltip-format": "Left: Open the application launcher\nRight: Show all keybindings"
  },

  "custom/appmenuicon": {
    "format": "ÔĆÉ",
    "on-click": "sleep 0.2;rofi -show drun -replace",
    "tooltip-format": "Left: Open the application launcher\nRight: Show all keybindings"
  },

  // Power Menu
  "custom/exit": {
    "format": " ůįź• ",
    "on-click": "~/.config/waybar/scripts/power-menu.sh",
    "tooltip-format": "Power Menu"
  },

  // Keyboard State
  "keyboard-state": {
    "numlock": true,
    "capslock": true,
    "format": "{name} {icon}",
    "format-icons": {
      "locked": "ÔÄ£",
      "unlocked": "Ôāú"
    }
  },

  // System tray
  "tray": {
    "icon-size": 21,
    "spacing": 10
  },

  // Clock (Japanese Date Format)
  "clock": {
    "interval": 60,
    "format": "{:%mśúą%dśó• %H:%M}",
    "max-length": 25,
    "on-click": "ags -t calendar",
    "tooltip-format": "<big>{:%YŚĻī %B}</big>\n<tt><small>{calendar}</small></tt>"
  },

  "niri/language": {
    "format": "/ K {short}"
  },

  // Battery
  "battery": {
    "states": {
      "warning": 30,
      "critical": 15
    },
    "format": "{icon}    {capacity}%",
    "format-charging": "Ôóß    {capacity}%",
    "format-plugged": "Ôá¶    {capacity}%",
    "format-alt": "{icon}    {time}",
    "format-icons": ["ÔČĄ ", "ÔČÉ ", "ÔČā ", "ÔČĀ ", "ÔČÄ "]
  },

  // Pulseaudio
  "pulseaudio": {
    "format": "{icon}    {volume}%",
    "format-bluetooth": "{volume}% {icon}ÔäĒ {format_source}",
    "format-bluetooth-muted": "Ôö© {icon}ÔäĒ {format_source}",
    "format-muted": "Ôö© {format_source}",
    "format-source": "{volume}% ÔĄį",
    "format-source-muted": "ÔĄĪ",
    "on-click": "pavucontrol"
  },

  // Bluetooth
  "bluetooth": {
    "format": "Ôäď {status}",
    "format-disabled": "",
    "format-off": "",
    "interval": 30,
    "on-click": "blueman-manager",
    "format-no-controller": ""
  },

  // User
  "user": {
    "format": "{user}",
    "interval": 60,
    "icon": false
  },

  // Backlight
  "backlight": {
    "format": "{icon}    {percent}%",
    "format-icons": ["Óéć", "ÓŹĒ", "ÓŹď", "ÓŹí", "ÓŹĎ", "ÓŹź", "ÓŹŹ", "ÓŹé", "ÓŹć", "ÓŹĆ", "ÓŹč", "ÓŹä", "ÓŹČ", "ÓŹą", "Óéõ"],
    "scroll-step": 1
  }
}
